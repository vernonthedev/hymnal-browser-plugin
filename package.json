{
  "type": "module",
  "name": "sda-hymnal-desktop",
  "version": "2.0.0",
  "description": "Electron desktop controller for the SDA Hymnal lower thirds backend",
  "main": "electron/main.js",
  "author": {
    "name": "vernonthedev",
    "email": "techjaja2@gmail.com",
    "url": "https://vernon.skope.au"
  },
  "license": "MIT",
  "scripts": {
    "dev": "bun run build:backend && electron .",
    "start": "bun run build:backend && electron .",
    "verify:build-assets": "node scripts/verify-build-assets.js",
    "prepare:dist": "node scripts/prepare-dist.js",
    "build:icons": "node scripts/build-icons.js",
    "build:backend": "tsc --outDir .",
    "dist": "bun run prepare:dist && bun run verify:build-assets && electron-builder --publish never",
    "dist:dir": "bun run prepare:dist && bun run verify:build-assets && electron-builder --dir --publish never",
    "dist:win": "bun run prepare:dist && bun run verify:build-assets && electron-builder --win nsis portable --publish never",
    "dist:mac": "bun run prepare:dist && bun run verify:build-assets && electron-builder --mac dmg --publish never",
    "dist:linux": "bun run prepare:dist && bun run verify:build-assets && electron-builder --linux AppImage deb --publish never"
  },
  "build": {
    "appId": "com.sda.hymnal.desktop",
    "productName": "Hymn Broadcast Console",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "icon": "assets/icons",
    "files": [
      "electron/**/*",
      "assets/**/*",
      "overlays/**/*",
      "hymns/**/*",
      "server.py",
      "README.md",
      "requirements.txt"
    ],
    "extraResources": [
      {
        "from": "dist/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "overlays",
        "to": "overlays",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "overlay.css",
          "overlay-client.js"
        ]
      },
      {
        "from": "hymns",
        "to": "hymns",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "CHANGELOG.md",
        "to": "CHANGELOG.md"
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist/electron"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icons/app.ico"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${os}-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${os}-${arch}-portable.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/app.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "category": "Utility",
      "maintainer": "vernonthedev <techjaja2@gmail.com>",
      "icon": "assets/icons",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "@elysiajs/cors": "^1.1.1",
    "@elysiajs/static": "^1.1.1",
    "elysia": "^1.1.12",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "icon-gen": "^3.0.1",
    "typescript": "^6.0.3"
  }
}
