{
  "name": "sda-hymnal-desktop",
  "version": "2.0.0",
  "description": "Electron desktop controller for the SDA Hymnal lower thirds backend",
  "main": "electron/main.js",
  "author": "vernonthedev",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "verify:build-assets": "node scripts/verify-build-assets.js",
    "build:icons": "node scripts/build-icons.js",
    "build:backend": "bun run verify:build-assets && node scripts/build-backend.js",
    "dist": "bun run verify:build-assets && electron-builder",
    "dist:dir": "bun run verify:build-assets && electron-builder --dir",
    "dist:win": "bun run verify:build-assets && electron-builder --win nsis",
    "dist:mac": "bun run verify:build-assets && electron-builder --mac dmg",
    "dist:linux": "bun run verify:build-assets && electron-builder --linux AppImage deb"
  },
  "build": {
    "appId": "com.sda.hymnal.desktop",
    "productName": "Hymn Broadcast Console",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "icon": "assets/icons",
    "files": [
      "electron/**/*",
      "assets/**/*",
      "overlays/**/*",
      "hymns/**/*",
      "server.py",
      "README.md",
      "requirements.txt"
    ],
    "extraResources": [
      {
        "from": "dist/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist/electron"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icons/app.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/app.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "icon": "assets/icons",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "icon-gen": "^3.0.1"
  }
}
