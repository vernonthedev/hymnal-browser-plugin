{
  "name": "sda-hymnal-desktop",
  "version": "2.0.0",
  "description": "Electron desktop controller for the SDA Hymnal lower thirds backend",
  "main": "electron/main.js",
  "author": "vernonthedev",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build:backend": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build_backend.ps1",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir"
  },
  "build": {
    "appId": "com.sda.hymnal.desktop",
    "productName": "SDA Hymnal Desktop",
    "files": [
      "electron/**/*",
      "assets/**/*",
      "overlays/**/*",
      "hymns/**/*",
      "server.py",
      "README.md",
      "requirements.txt"
    ],
    "extraResources": [
      {
        "from": "dist/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist/electron"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12"
  }
}
