{
  "name": "sda-hymnal-desktop",
  "version": "2.0.0",
  "description": "Electron desktop controller for the SDA Hymnal lower thirds backend",
  "type": "module",
  "main": "electron/main.js",
  "author": {
    "name": "vernonthedev",
    "email": "techjaja2@gmail.com",
    "url": "https://vernon.skope.au"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron . --disable-gpu --disable-software-rasterizer",
    "start": "electron . --disable-gpu --disable-software-rasterizer",
    "verify:build-assets": "node scripts/verify-build-assets.js",
    "prepare:dist": "node scripts/prepare-dist.js",
    "build:icons": "node scripts/build-icons.js",
    "dist": "npm run prepare:dist && npm run verify:build-assets && electron-builder --publish never",
    "dist:dir": "npm run prepare:dist && npm run verify:build-assets && electron-builder --dir --publish never",
    "dist:win": "npm run prepare:dist && npm run verify:build-assets && electron-builder --win nsis portable --publish never",
    "dist:mac": "npm run prepare:dist && npm run verify:build-assets && electron-builder --mac dmg --publish never",
    "dist:linux": "npm run prepare:dist && npm run verify:build-assets && electron-builder --linux AppImage deb --publish never"
  },
  "build": {
    "appId": "com.sda.hymnal.desktop",
    "productName": "Hymn Broadcast Console",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "icon": "assets/icons",
    "files": [
      "electron/**/*",
      "assets/**/*",
      "overlays/**/*",
      "hymns/**/*",
      "README.md"
    ],
    "extraResources": [
      {
        "from": "overlays",
        "to": "overlays",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "overlay.css",
          "overlay-client.js"
        ]
      },
      {
        "from": "hymns",
        "to": "hymns",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "CHANGELOG.md",
        "to": "CHANGELOG.md"
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist/electron"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icons/app.ico"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${os}-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${os}-${arch}-portable.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/app.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "category": "Utility",
      "maintainer": "vernonthedev <techjaja2@gmail.com>",
      "icon": "assets/icons",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "icon-gen": "^3.0.1",
    "lefthook": "^2.1.6",
    "typescript": "^6.0.3"
  },
  "config": {
    "commitizen": {
        "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
